# Stats section — copy to `.env` and fill in. All are optional:
# if unset, the corresponding fetch is skipped and Stats fall back to
# cached values (localStorage) or zeros, so the site still renders.

# Base hostname of your portfolio backend API (no trailing slash)
VITE_PORTFOLIO_API_HOSTNAME=

# Path segments appended to the hostname for each endpoint.
# LeetCode endpoint has the username appended to the end.
VITE_PORTFOLIO_API_LEETCODE_ENDPOINT=
VITE_PORTFOLIO_API_GITHUB_ENDPOINT=

# Your LeetCode username (appended to the LeetCode endpoint) and
# used for the GitHub summary card. Defaults to the GitHub handle in constants.
VITE_USERNAME=

# Optional: abstractapi.com geolocation key (legacy analytics side effect)
VITE_GEO_API_KEY=

# Moonmind chatbot — chat generation endpoint path, appended to the hostname
# above. e.g. "/moonmind/chat". Unset => the chatbot shows a config notice.
VITE_PORTFOLIO_API_MOONMIND_CHAT_ENDPOINT=

# Résumé — external link (e.g. Google Drive) used by the "Download Résumé"
# buttons. Unset => the buttons link to "#".
VITE_RESUME_URL=
